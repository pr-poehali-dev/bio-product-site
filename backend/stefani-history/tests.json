{
  "tests": [
    {
      "name": "OPTIONS preflight",
      "method": "OPTIONS",
      "path": "/",
      "expectedStatus": 200
    },
    {
      "name": "GET without session_id returns 400",
      "method": "GET",
      "path": "/",
      "expectedStatus": 400,
      "expectedBody": {"error": "session_id required"},
      "bodyMatcher": "partial"
    },
    {
      "name": "POST save messages",
      "method": "POST",
      "path": "/",
      "body": {
        "session_id": "test-session-002",
        "mood": "calm",
        "messages": [
          {"role": "user", "text": "Тест памяти", "emotion": "neutral"},
          {"role": "stefani", "text": "Помню тебя.", "emotion": "happy"}
        ]
      },
      "expectedStatus": 200,
      "expectedBody": {"saved": 2},
      "bodyMatcher": "partial"
    },
    {
      "name": "GET history for session",
      "method": "GET",
      "path": "/?session_id=test-session-002",
      "expectedStatus": 200,
      "expectedBody": {"mood": "calm"},
      "bodyMatcher": "partial"
    }
  ]
}
